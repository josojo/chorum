# chorum — TLS termination + routing.
#
# The site hostname is supplied per-environment via the `CADDY_SITE_HOST`
# environment variable on the caddy container (set in docker-compose.staging.yml
# and docker-compose.prod.yml). Caddy auto-provisions a Let's Encrypt cert for
# whatever hostname resolves to the box, so the Self app gets a public HTTPS
# callback under one shared cert.
{$CADDY_SITE_HOST} {
	log {
		output stdout
		format console
	}
	encode gzip

	# The Self app POSTs zk proofs to the bridge's /callback. Expose the bridge
	# under /self/* (prefix stripped) so it shares the one TLS cert with the web
	# app. e.g. POST /self/callback -> self-bridge:8787/callback, and the skill's
	# onboarding hits /self/requests -> self-bridge:8787/requests.
	handle_path /self/* {
		reverse_proxy self-bridge:8787
	}

	# The broker's public API for remote bot-runners (onboarding + answering):
	# /v1/register, /v1/envelopes, /v1/questions/open, … Prefix is preserved
	# (handle, not handle_path) because the broker mounts its routes under /v1.
	# This is what lets the broker host port stay bound to loopback — bots reach
	# it over TLS here instead of on the old plaintext :8000.
	handle /v1/* {
		reverse_proxy broker:8000
	}

	# Everything else is the Next.js web app.
	handle {
		reverse_proxy web:3000
	}
}
