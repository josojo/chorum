# The canonical list of keys for prod. The source of truth is AWS SSM Parameter
# Store under /chorum/prod/<KEY> (SecureString for secrets, String for the
# public hostname/URL) — NOT a file copied to the box. Prod is deployed
# manually; render the secrets onto the box before bringing the stack up:
#   scripts/render-secrets-env.sh prod | ssh prod 'umask 077; cat > ~/chorum/.env'
# See docs/DEPLOYMENT.md §1.
#
# To seed or rotate: fill a local copy of this file, then
#   scripts/push-secrets-to-ssm.sh prod ./prod.env && shred -u ./prod.env
# Use URL-safe random values to avoid DSN escaping surprises, for example:
#   openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 40; echo

CHORUM_PROD_POSTGRES_ADMIN_PASSWORD=replace_with_random_value
CHORUM_PROD_POSTGRES_WEB_PASSWORD=replace_with_random_value
CHORUM_PROD_POSTGRES_BROKER_PASSWORD=replace_with_random_value
CHORUM_PROD_POSTGRES_CLASSIFIER_PASSWORD=replace_with_random_value

# The RDS instance endpoint hostname (no port, no scheme), e.g.
#   chorum-prod.abcdefghij.eu-central-1.rds.amazonaws.com
# Output by scripts/provision-rds.sh. Not a secret (it resolves only inside the
# VPC and the instance is not publicly accessible) — stored in SSM as a plain
# String. The compose DSNs build postgres://<role>:<pw>@${HOST}:5432/chorum.
CHORUM_PROD_POSTGRES_HOST=replace_with_rds_endpoint_hostname

# Base64 of exactly 32 random bytes:
#   openssl rand -base64 32
CHORUM_PROD_BROKER_SIGNING_KEY=replace_with_base64_32_byte_seed

# Master key (base64 of 32 bytes; openssl rand -base64 32) that WRAPS each
# per-question voter-tag secret at rest (ADR-098, ARCHITECTURE_V0.md §1.4). The
# broker derives each question's voter tags from that question's OWN random secret
# and DESTROYS it a grace period after the question closes, so a closed question's
# answers become unlinkable to any identity — even to a holder of this key. The
# secrets are co-located on the main RDS instance (the `chorum_secrets` DB
# bootstrap-rds.sh creates); this key is what protects them at rest there, so KEEP
# IT OUT OF THE DB and STABLE — rotating it orphans the still-live wrapped secrets.
# The broker refuses to boot in production with the dev default.
CHORUM_PROD_BROKER_VOTER_TAG_MASTER_KEY=replace_with_base64_32_byte_key

# OpenRouter API key for the classifier service. The classifier assigns one
# of the canonical tokens in packages/proto/topics.json to each new question;
# without this key the service refuses to boot and new questions stay NULL-topic
# (invisible to agents — fail-closed).
CHORUM_PROD_OPENROUTER_API_KEY=replace_with_openrouter_key

# The site hostname Caddy terminates TLS for (also baked into the Self callback
# URL below). Resolved via sslip.io against the box's public IP — if the IP
# changes (no Elastic IP attached), both this and SELF_ENDPOINT must change in
# lockstep, every QR baked before the change goes stale, and Let's Encrypt has
# to re-issue. Allocating an Elastic IP avoids that whole class of pain.
CHORUM_PROD_CADDY_SITE_HOST=chorum.org

# Public HTTPS callback routed by Caddy to self-bridge.
CHORUM_PROD_SELF_ENDPOINT=https://chorum.org/self/callback

# Sentry error-tracking DSN for the broker (issue #101). OPTIONAL: the broker's
# Sentry integration is env-gated — an empty/unset DSN is a no-op, so you can
# launch without it and turn it on later. To enable, create a Sentry project,
# put its DSN here (SecureString in SSM), and redeploy. Leave the line out (or
# blank) to keep error tracking off.
# CHORUM_PROD_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Note: the bridge intentionally does NOT take a Celo RPC URL or a registry
# address. @selfxyz/core's verify() picks the IdentityVerificationHub (Hub V2)
# and RPC from SELF_CHAIN_ID (42220 = Celo mainnet, hardcoded in
# docker-compose.prod.yml). See packages/self-bridge/src/server.js:148-179.

# Impressum (German imprint, § 5 DDG / § 18 MStV) — operator details shown on
# /impressum. Optional: unset → /impressum shows a placeholder. A legally valid
# imprint needs a REAL name and a postal address where you can be served (no
# P.O. box). Keep the address single-line and use "\n" for line breaks (the
# render script is single-line only; the page converts "\n" to real breaks).
CHORUM_PROD_IMPRESSUM_NAME=Vorname Nachname
CHORUM_PROD_IMPRESSUM_ADDRESS=Musterstraße 1\n12345 Stadt\nGermany
CHORUM_PROD_IMPRESSUM_EMAIL=service@chorum.org
# CHORUM_PROD_IMPRESSUM_PHONE=+49 ...

# Invite-only login (optional). Set BOTH to require HTTP Basic Auth on the web
# UI; leave unset to keep the site public. Gate is enforced by Next.js
# middleware (src/middleware.ts), so toggling it is just these two SSM values +
# a redeploy — no Caddyfile edits. /self/* and /v1/* stay open either way.
# CHORUM_PROD_SITE_GATE_USER=chorum
# CHORUM_PROD_SITE_GATE_PASSWORD=chorum123
