# Copy to /home/ubuntu/hearme/.env on the prod host. Do not commit the real
# file. Use URL-safe random values to avoid DSN escaping surprises, for example:
#   openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 40; echo

HEARME_PROD_POSTGRES_ADMIN_PASSWORD=replace_with_random_value
HEARME_PROD_POSTGRES_WEB_PASSWORD=replace_with_random_value
HEARME_PROD_POSTGRES_BROKER_PASSWORD=replace_with_random_value

# Base64 of exactly 32 random bytes:
#   openssl rand -base64 32
HEARME_PROD_BROKER_SIGNING_KEY=replace_with_base64_32_byte_seed

# The site hostname Caddy terminates TLS for (also baked into the Self callback
# URL below). Resolved via sslip.io against the box's public IP — if the IP
# changes (no Elastic IP attached), both this and SELF_ENDPOINT must change in
# lockstep, every QR baked before the change goes stale, and Let's Encrypt has
# to re-issue. Allocating an Elastic IP avoids that whole class of pain.
HEARME_PROD_CADDY_SITE_HOST=3-74-46-46.sslip.io

# Public HTTPS callback routed by Caddy to self-bridge.
HEARME_PROD_SELF_ENDPOINT=https://3-74-46-46.sslip.io/self/callback

# Optional override; defaults to https://forno.celo.org (Celo mainnet RPC).
# HEARME_PROD_SELF_CELO_RPC_URL=https://forno.celo.org

# Self's IdentityVerificationHub on Celo mainnet. Confirm against
# https://docs.self.xyz before rotating.
HEARME_PROD_SELF_REGISTRY_ADDRESS=0x_replace_with_mainnet_hub_address
