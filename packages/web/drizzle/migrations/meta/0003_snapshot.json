      "checkConstraints": {
        "questions_status_chk": {
          "name": "questions_status_chk",
          "value": "\"questions\".\"status\" IN ('open', 'closed')"
        },
        "questions_scope_chk": {
          "name": "questions_scope_chk",
          "value": "\"questions\".\"scope\" IN ('worldwide','continent','country')"
        },
        "questions_options_chk": {
          "name": "questions_options_chk",
          "value": "jsonb_typeof(\"questions\".\"options\") = 'array' AND jsonb_array_length(\"questions\".\"options\") BETWEEN 2 AND 8"
        },
        "questions_continent_chk": {
          "name": "questions_continent_chk",
          "value": "\"questions\".\"continent\" IS NULL OR \"questions\".\"continent\" IN ('AF','AN','AS','EU','NA','OC','SA')"
        },
        "questions_scope_geo_chk": {
          "name": "questions_scope_geo_chk",
          "value": "(\"questions\".\"scope\" = 'worldwide' AND \"questions\".\"country\" IS NULL AND \"questions\".\"continent\" IS NULL)\n        OR (\"questions\".\"scope\" = 'continent' AND \"questions\".\"country\" IS NULL AND \"questions\".\"continent\" IS NOT NULL)\n        OR (\"questions\".\"scope\" = 'country' AND \"questions\".\"country\" IS NOT NULL AND \"questions\".\"continent\" IS NOT NULL)"
        }
      },
