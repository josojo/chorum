{
  "name": "hearme-broker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Hearme v0 dispatcher and envelope verifier (ARCHITECTURE_V0.md §5). TypeScript port of the broker: Fastify + Drizzle (reusing packages/web schema.ts) + tweetnacl Ed25519.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "admin": "tsx src/admin-cli.ts"
  },
  "dependencies": {
    "@sentry/node": "^8.55.2",
    "drizzle-orm": "^0.36.0",
    "fastify": "^4.28.1",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^20.11.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.0",
    "vitest": "^2.1.2"
  }
}
