# The canonical list of keys for staging. The source of truth is AWS SSM
# Parameter Store under /hearme/staging/<KEY> (SecureString for secrets, String
# for the public hostname/URL) — NOT a file copied to the box. The deploy
# workflow renders these onto the box as ~/hearme/.env each deploy
# (scripts/render-secrets-env.sh); see docs/DEPLOYMENT.md §1.
#
# To seed or rotate: fill a local copy of this file, then
#   scripts/push-secrets-to-ssm.sh staging ./staging.env && shred -u ./staging.env
# Use URL-safe random values to avoid DSN escaping surprises, for example:
#   openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 40; echo

HEARME_STAGING_POSTGRES_ADMIN_PASSWORD=replace_with_random_value
HEARME_STAGING_POSTGRES_WEB_PASSWORD=replace_with_random_value
HEARME_STAGING_POSTGRES_BROKER_PASSWORD=replace_with_random_value
HEARME_STAGING_POSTGRES_CLASSIFIER_PASSWORD=replace_with_random_value

# Base64 of exactly 32 random bytes:
#   openssl rand -base64 32
HEARME_STAGING_BROKER_SIGNING_KEY=replace_with_base64_32_byte_seed

# Master key (base64 of 32 bytes; openssl rand -base64 32) that wraps each
# per-question voter-tag secret at rest (ADR-098, §1.4). The secrets live in the
# broker-owned `hearme_secrets` DB on the box's container Postgres (the DSN is
# derived from HEARME_STAGING_POSTGRES_BROKER_PASSWORD in docker-compose.staging.yml).
HEARME_STAGING_BROKER_VOTER_TAG_MASTER_KEY=replace_with_base64_32_byte_key

# OpenRouter API key for the classifier service. The classifier assigns one
# of the canonical tokens in packages/proto/topics.json to each new question;
# without this key the service refuses to boot and new questions stay NULL-topic
# (invisible to agents — fail-closed).
HEARME_STAGING_OPENROUTER_API_KEY=replace_with_openrouter_key

# The site hostname Caddy terminates TLS for (also baked into the Self
# callback URL below). Resolved via sslip.io against the box's public IP.
HEARME_STAGING_CADDY_SITE_HOST=3-121-186-133.sslip.io

# Public HTTPS callback routed by Caddy to self-bridge.
HEARME_STAGING_SELF_ENDPOINT=https://3-121-186-133.sslip.io/self/callback

# Impressum (German imprint, § 5 DDG / § 18 MStV) — operator details shown on
# /impressum. Optional: unset → /impressum shows a placeholder. A legally valid
# imprint needs a REAL name and a postal address where you can be served (no
# P.O. box). Keep the address single-line and use "\n" for line breaks (the
# render script is single-line only; the page converts "\n" to real breaks).
HEARME_STAGING_IMPRESSUM_NAME=Vorname Nachname
HEARME_STAGING_IMPRESSUM_ADDRESS=Musterstraße 1\n12345 Stadt\nGermany
HEARME_STAGING_IMPRESSUM_EMAIL=service@chorum.org
# HEARME_STAGING_IMPRESSUM_PHONE=+49 ...
